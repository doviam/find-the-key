# Copia este archivo a .env en la carpeta backend/ (o exporta las variables en tu shell)

# Obligatorio solo para la capa IA (si no está, verás un informe de respaldo sin OpenAI)
OPENAI_API_KEY=sk-...

# Opcional: modelo de chat (por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Spotify Web API (client credentials) — GET /recommendations
# SPOTIFY_CLIENT_ID=...
# SPOTIFY_CLIENT_SECRET=...

# Orígenes CORS permitidos (coma separada) si sirves el frontend en otro puerto
# CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8000
